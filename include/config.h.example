#ifndef CONFIG_H
#define CONFIG_H

// ============================================
// LED Configuration
// ============================================
#ifndef LED_PIN
#define LED_PIN 3
#endif

#ifndef NUM_LEDS
#define NUM_LEDS 20
#endif

#define MAX_BRIGHTNESS 255
#define DEFAULT_BRIGHTNESS 150

// ============================================
// WiFi Configuration
// ============================================
#define WIFI_SSID "YourNetworkSSID"
#define WIFI_PASSWORD "your_wifi_password"

// Static IP Configuration
#define STATIC_IP_ENABLED true
#define STATIC_IP      192, 168, 1, 252
#define GATEWAY_IP     192, 168, 1, 1
#define SUBNET_MASK    255, 255, 255, 0
#define DNS_IP         192, 168, 1, 1

// ============================================
// Access Point Configuration (Fallback)
// ============================================
#define AP_SSID "LED-Star"
#define AP_PASSWORD "your_ap_password"
#define AP_CHANNEL 1
#define AP_MAX_CONNECTIONS 4
#define AP_IP          192, 168, 4, 1
#define WIFI_CONNECT_TIMEOUT 15

// ============================================
// OTA Configuration
// ============================================
#define OTA_ENABLED true
#define OTA_HOSTNAME "led-star"
#define OTA_PASSWORD ""

// ============================================
// Web Server Configuration
// ============================================
#define WEB_SERVER_PORT 80

// ============================================
// Effects Configuration
// ============================================
#define EFFECT_SPEED_DEFAULT 50
#define EFFECT_SPEED_MIN 1
#define EFFECT_SPEED_MAX 255

// ============================================
// EEPROM Configuration
// ============================================
#define EEPROM_SIZE 64
#define EEPROM_EFFECT_ADDR 0
#define EEPROM_BRIGHTNESS_ADDR 1
#define EEPROM_SPEED_ADDR 2
#define EEPROM_COLOR_R_ADDR 3
#define EEPROM_COLOR_G_ADDR 4
#define EEPROM_COLOR_B_ADDR 5
#define EEPROM_AUTOCYCLE_ADDR 6
#define EEPROM_CYCLETIME_HI_ADDR 7
#define EEPROM_CYCLETIME_LO_ADDR 8
#define EEPROM_MAGIC_ADDR 10
#define EEPROM_MAGIC_VALUE 0xAB
#define EEPROM_PALETTE_SIZE_ADDR 11
#define EEPROM_PALETTE_START_ADDR 12  // 12 + (index * 3) for R, +1 for G, +2 for B

#endif // CONFIG_H
